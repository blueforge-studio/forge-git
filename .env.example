# ─── Gitea ─────────────────────────────────────────────────────────────────
FORGE_GIT_URL=http://git.localhost:3001
FORGE_GIT_TOKEN=

# ─── OAuth2 (for "Sign in with Gitea" flow) ────────────────────────────────
# Register an OAuth2 app in your Gitea instance at /admin/applications
# GITEA_OAUTH_CLIENT_ID=
# GITEA_OAUTH_CLIENT_SECRET=
# GITEA_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ─── Session (iron-session via @blueforge-studio/auth-session) ─────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
# SESSION_SECRET=

# ─── Database (PostgreSQL for forge-git metadata) ──────────────────────────
DATABASE_URL=postgresql://forge-git:forge-git@localhost:5432/forge-git

# ─── Webhook ───────────────────────────────────────────────────────────────
# Secret for HMAC-SHA256 webhook payload validation.
# GITEA_WEBHOOK_SECRET=

# ─── Redis (BullMQ + Cache) ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── MinIO (S3-compatible artifact storage) ────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=forge-git-builds
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ─── Service Factory providers (override to switch backends) ───────────────
# DATABASE_PROVIDER=postgres     # postgres | supabase | console
# CACHE_PROVIDER=ioredis         # ioredis | upstash | memory
# QUEUE_PROVIDER=bullmq           # bullmq | qstash | memory
# STORAGE_PROVIDER=minio         # minio | backblaze_b2 | cloudflare_r2 | memory
# EMAIL_PROVIDER=mailstack       # mailstack | resend | console
# GIT_PROVIDER=forge-git          # forge-git | github | gitlab | console
# ERROR_TRACKER_PROVIDER=self-hosted  # self-hosted | sentry | console

# ─── Comms (multi-channel notifications) ───────────────────────────────────
# SLACK_WEBHOOK_URL=
# DISCORD_WEBHOOK_URL=
# RESEND_API_KEY=
# COMMS_WEBHOOK_URL=
