# ─── Gitea ─────────────────────────────────────────────────────────────────
FORGE_GIT_URL=http://git.localhost:3001
FORGE_GIT_TOKEN=

# ─── OAuth2 (for "Sign in with Gitea" flow) ────────────────────────────────
# Register an OAuth2 app in your Gitea instance at /admin/applications
# GITEA_OAUTH_CLIENT_ID=
# GITEA_OAUTH_CLIENT_SECRET=
# GITEA_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ─── Session ───────────────────────────────────────────────────────────────
# HMAC-SHA256 key for OAuth session cookies. Generate with: openssl rand -hex 32
# SESSION_SECRET=

# ─── Webhook ───────────────────────────────────────────────────────────────
# Secret for HMAC-SHA256 webhook payload validation. Generate with: fgit webhook generate-secret
# GITEA_WEBHOOK_SECRET=

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── MinIO (S3-compatible artifact storage) ────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=forge-git-builds
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
