{
  "name": "@forge-git/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./schema": "./src/schema.ts",
    "./orgs": "./src/orgs.ts",
    "./members": "./src/members.ts",
    "./users": "./src/users.ts",
    "./auth-adapter": "./src/auth-adapter.ts"
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
